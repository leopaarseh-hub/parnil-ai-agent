# ─────────────────────────────────────────────────────────────────────────
# Parnil AI Agent — environment variables
# Copy this file to .env.local (local dev) or set them in your host (Vercel).
# NEVER commit real values. .env* is git-ignored (except this example).
# ─────────────────────────────────────────────────────────────────────────

# REQUIRED — powers the AI Growth Consultant and brief generation.
# Get a FREE key at https://aistudio.google.com/apikey (no credit card needed).
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# OPTIONAL — public URL where this app is hosted (self-referential links).
APP_URL="https://your-app.example.com"

# ─── Lead capture (optional) ─────────────────────────────────────────────
# If unset, lead capture is skipped gracefully and the brief still works.
# SUPABASE_URL: your project URL, e.g. https://xxxx.supabase.co
SUPABASE_URL=""

# Provide ONE of the following keys (most → least privileged).
# - SERVICE_ROLE bypasses RLS (server-only; keep secret).
# - ANON / PUBLISHABLE is insert-only via the RLS policy (safe to expose).
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_ANON_KEY=""
SUPABASE_PUBLISHABLE_KEY=""
