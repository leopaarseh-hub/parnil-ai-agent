# GEMINI_API_KEY: Required — powers the AI Growth Consultant and brief generation.
# Get a FREE key at https://aistudio.google.com/apikey (no credit card needed).
# Copy this file to .env.local for local development and paste your key below.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The public URL where this app is hosted.
# Used for self-referential links and API endpoints.
APP_URL="MY_APP_URL"
